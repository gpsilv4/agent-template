{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)"
    ],
    "allow": [
      "Read(.agent/**)",
      "Bash(node .agent/scripts/*)",
      "Bash(npx tsc --noEmit)",
      "Bash(npm run lint*)",
      "Bash(npm run test:*)"
    ]
  }
}
